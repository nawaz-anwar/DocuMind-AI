{
  "name": "documind-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @documind/shared-types build && pnpm --filter @documind/utils build && pnpm --filter backend build",
    "build:frontend": "pnpm --filter @documind/shared-types build && pnpm --filter frontend build",
    "start": "pnpm --parallel -r start",
    "backend:dev": "pnpm --filter backend dev",
    "frontend:dev": "pnpm --filter frontend dev",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
